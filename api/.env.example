# Storage/Cloudflare
STORAGE_ENDPOINT=your-endpoint-here
STORAGE_REGION=auto
STORAGE_ACCESS_KEY_ID=your-access-key-id-here
STORAGE_SECRET_ACCESS_KEY=your-secret-access-key-here
STORAGE_FORCE_PATH_STYLE=true
STORAGE_BUCKET_NAME=your-bucket-name

# API Setup
PORT=3333
NODE_ENV=development

# Redis Variables
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here